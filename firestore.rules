rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bookings
    // Fields: name (string), phone (string), date (string), time (string), guests (number), status (string), createdAt (timestamp)
    //
    // Collection: menuItems
    // Fields: name (string), description (string), price (number), category (string), image (string), isAvailable (bool)
    //
    // Collection: users
    // Fields: email (string), role (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ayansayyad010@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidBooking(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.date is string && data.time is string &&
             data.guests is number && data.guests > 0 && data.guests <= 50 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['Breakfast', 'Cold Drinks', 'Main Course', 'Desserts'] &&
             data.isAvailable is bool;
    }

    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'customer'];
    }

    function isValidVideo(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.url is string && data.url.size() > 0;
    }

    // Bookings: Customers can create, Admins can read/update all
    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    // MenuItems: Anyone can read, only Admins can write
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidMenuItem(request.resource.data);
    }

    // Videos: Anyone can read, only Admins can write
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidVideo(request.resource.data);
    }

    // Users: Only Admins can read all, Users can read/write their own
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'customer' || isAdmin());
    }
  }
}
